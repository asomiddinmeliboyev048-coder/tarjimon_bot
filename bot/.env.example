# ==========================================
# Tarjimon Bot - Environment Configuration
# ==========================================

# Telegram Bot Token (get from @BotFather)
BOT_TOKEN=your_bot_token_here

# Admin User ID (get your ID from @userinfobot)
ADMIN_ID=123456789

# Channel ID for subscription check
# Format: @channel_name or -1001234567890
# Leave empty to disable subscription check
CHANNEL_ID=-1001234567890

# Database path (SQLite)
DATABASE_PATH=bot.db

# ==========================================
# Optional Settings
# ==========================================

# Webhook mode (set to 'true' to use webhook instead of polling)
# USE_WEBHOOK=false
# WEBHOOK_URL=https://yourdomain.com/webhook
# WEBHOOK_PORT=8443
